# CPL Engine Client Configuration
# --------------------------------------------------
# LogLevel controls file logging verbosity
# Allowed values: Off, Error, Warning, Info, Debug
LogLevel=Info
# --------------------------------------------------
# Firmware version reported by this client
FirmwareVersion=3.1.20
# --------------------------------------------------
# EnableFolderWatcher controls background folder monitoring
# false = disabled (default, safe for all systems)
# true  = enabled (requires at least one WatchFolder entry)
EnableFolderWatcher=false
# --------------------------------------------------
# Add one or more WatchFolder entries to enable monitoring
# Each WatchFolder must be a valid existing directory
# Example:
# WatchFolder=C:\Logs
# WatchFolder=D:\ApplicationLogs

