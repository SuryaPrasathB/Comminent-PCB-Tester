  <property name="styleSheet">
   <string notr="true">
QWidget#ProjectConfigWidget {
    background-color: #f0f2f5;
}
QLabel {
    font-family: Arial, sans-serif;
    font-size: 14px;
    color: #555;
}
QLineEdit {
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 8px;
    background-color: white;
    font-size: 14px;
    selection-background-color: #0078d7;
    color: #333;
}

/* 🔑 Compact combo for tables */
QComboBox {
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 2px 4px;     /* ✅ FIX */
    font-size: 13px;      /* ✅ FIX */
    background-color: white;
    color: #333;
}

QComboBox::drop-down {
    width: 16px;
    border: none;
}

QComboBox::down-arrow {
    width: 8px;
    height: 8px;
}

QLineEdit:focus, QComboBox:focus {
    border: 1px solid #0078d7;
}
QPushButton {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #0078d7, stop:1 #005a9e);
    color: white;
    font-family: Arial, sans-serif;
    font-size: 14px;
    font-weight: bold;
    padding: 10px;
    border-radius: 5px;
    border: none;
}
QPushButton:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #0088e7, stop:1 #006ac1);
}
QPushButton:pressed {
    background-color: #004578;
}
QGroupBox {
    font-family: Arial, sans-serif;
    font-weight: bold;
    color: #333;
    border: 1px solid #ccc;
    border-radius: 5px;
    margin-top: 10px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px 0 5px;
}
QTableWidget {
    border: 1px solid #ccc;
    border-radius: 5px;
    font-family: Arial, sans-serif;
    font-size: 14px;
    background-color: white;
    selection-background-color: #0078d7;
}
QHeaderView::section {
    background-color: #e9ecef;
    padding: 8px;
    border: 1px solid #ccc;
    font-weight: bold;
}
QTableWidget::item {
    padding: 1px;
}
QTableWidget::alternating-row-color {
    background-color: #f8f9fa;
}
   </string>
